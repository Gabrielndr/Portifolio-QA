{
  "name": "cypress-portifolio-qa",
  "version": "1.0.0",
  "description": "Testes E2E com Cypress - Portfólio QA Gabriel da Silva",
  "scripts": {
    "cy:run": "cypress run",
    "cy:open": "cypress open",
    "cy:allure": "cypress run --reporter mocha-allure-reporter",
    "allure:generate": "allure generate allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report"
  },
  "devDependencies": {
    "cypress": "^13.0.0",
    "@4tw/cypress-drag-drop": "^2.2.5",
    "mocha-allure-reporter": "^1.4.0",
    "allure-commandline": "^2.29.0"
  }
}
